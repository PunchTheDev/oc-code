+        let db = test_db();
+        db.conn
+            .lock()
+            .unwrap()
+            .execute(
+                "INSERT INTO draft_sessions (draft_code, session_json, updated_at) VALUES (?1, ?2, ?3)",
+                params!["OLDDRAFT", "old", 1000u64],
