+const Base = z.object({
+  a: z.string(),
+  b: z.string()
+}).check(z.refine(user => user.a === user.b));
+
+// Extended inherits the refinements of Base
+const Extended = z.safeExtend(UserSchema, {
+  a: z.string().min(10)
