+/* ---- Episode import scan polish (#86) ---- */
+.setup-import-flow {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px 18px;
+  margin-bottom: 22px;
+  padding: 12px 16px;
+  background: #f6f5ff;
+  border-radius: 12px;
+  border: 1px solid var(--line);
+}
+
+.setup-flow-step {
+  font-size: 13px;
+  font-weight: 600;
+  color: var(--ink-soft);
+}
+
+.setup-flow-step.is-current {
+  color: var(--brand);
+}
+
+.setup-section-head {
+  display: flex;
+  align-items: flex-start;
+  gap: 14px;
+  margin-bottom: 18px;
+}
+
+.setup-section-number {
+  flex-shrink: 0;
+  width: 28px;
+  height: 28px;
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  border-radius: 999px;
+  background: rgba(108, 76, 255, 0.12);
+  color: var(--brand);
+  font-weight: 700;
+  font-size: 13px;
+  margin-top: 2px;
+}
+
+.setup-section-title-block h2 {
+  margin: 0 0 6px;
+}
+
+.setup-section-title-block .setup-section-lead {
+  margin: 0;
+}
+
+.setup-section-episode,
+.setup-section-source,
+.setup-speakers-card {
+  scroll-margin-top: 16px;
+}
+
+.setup-role-overview {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  margin: -4px 0 18px;
+}
+
+.setup-role-chip {
+  font-size: 12px;
+  font-weight: 700;
+  padding: 5px 12px;
+  border-radius: 999px;
+  border: 1px solid var(--line);
+  background: #fff;
+  color: var(--ink);
+}
+
+.setup-speakers-card .speaker-stack {
+  gap: 24px;
+}
+
+.speaker-card {
+  padding: 24px 26px;
+}
+
+.speaker-head-main {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 10px 12px;
+}
+
+.speaker-role-badge {
+  font-weight: 700;
+  font-size: 12px;
+  padding: 4px 10px;
+  border-radius: 999px;
+  background: rgba(108, 76, 255, 0.1);
+  color: var(--brand);
+}
+
+.speaker-group {
+  padding: 16px 18px;
+  border-radius: 12px;
+  background: #fff;
+  border: 1px solid var(--line);
+}
+
+.speaker-group-title {
+  font-size: 12px;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.06em;
+  color: var(--ink-soft);
+  margin: 0 0 12px;
+}
+
+.speaker-social-group summary {
+  font-size: 12px;
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.06em;
+  color: var(--ink-soft);
+  list-style: none;
+}
+
+.speaker-social-group summary::-webkit-details-marker {
+  display: none;
+}
+
+.speaker-social-group[open] summary {
+  margin-bottom: 10px;
+  color: var(--brand);
+  text-transform: none;
+  letter-spacing: normal;
+  font-size: 14px;
+}
+
+.setup-add-speaker-btn {
+  width: 100%;
+  justify-self: start;
+  margin-top: 4px;
+}
+
+.setup-draft-review {
+  padding: 14px 18px;
+  margin-bottom: 4px;
+  border-radius: 12px;
+  border: 1px dashed var(--line);
+  background: #fafafe;
+}
+
+.setup-draft-review-text {
+  margin: 0;
+  font-size: 14px;
+  line-height: 1.5;
+  color: var(--ink);
+}
+
+.setup-draft-review-text strong {
+  color: var(--ink);
+}
+
+@media (max-width: 720px) {
+  .setup-import-flow {
+    flex-direction: column;
+    gap: 8px;
+  }
+
+  .speaker-card {
+    padding: 18px 16px;
+  }
+
+  .speaker-group {
+    padding: 14px 14px;
+  }
+
+  .speaker-head {
+    flex-wrap: wrap;
+    gap: 10px;
+  }
+}
+
 .brand-kit-line {
   font-weight: 600;
   margin: 0 0 8px;
