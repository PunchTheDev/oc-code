+            doctor.card_type.subtypes
+        );
+
+        let db = CardDatabase::from_mtgjson(&path).expect("db load");
+        assert!(
+            can_pair_commanders(&db, "Amy Pond", "The Eleventh Doctor"),
+            "full MTGJSON database load must agree on Doctor's Companion pairing"
+        );
