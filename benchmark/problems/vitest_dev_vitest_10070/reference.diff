+            "ran": true,
+          },
+          "state": "passed",
+        },
+        "hello world": {
+          "meta": {
+            "ran": true,
+          },
+          "state": "skipped",
+        },
+      },
+      "b.test.js": {
+        "another foo": {
+          "meta": {
+            "ran": true,
+          },
+          "state": "passed",
+        },
+        "unrelated": {
+          "meta": {
+            "ran": true,
+          },
+          "state": "skipped",
+        },
+      },
+    }
+  `)
+})
+
+test('does not execute files where all tests are filtered by testNamePattern', async () => {
+  const { buildTree, stderr } = await runInlineTests({
+    'a.test.js': `
+      import { test } from 'vitest'
