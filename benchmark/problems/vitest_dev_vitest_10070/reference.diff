+})
+
+test('filters tests by testLines', async () => {
+  const { fs, ctx, buildTree } = await runInlineTests({
+    // line 1: import
+    // line 2: test 1
+    // line 3: test 2
+    'a.test.js': `import { test } from 'vitest'
+test('test 1', { meta: { ran: true } }, () => {})
+test('test 2', { meta: { ran: true } }, () => {})
