diff --git a/tests/test_options.py b/tests/test_options.py
index 2b052a31c..4200ab905 100644
--- a/tests/test_options.py
+++ b/tests/test_options.py
@@ -262,3 +262,19 @@ class AddFieldsChild(self.AddFieldsSchema):
