# =============================================================================
# ActiveLearningAI Configuration
# =============================================================================
# Copy this file to .env and customize as needed

# =============================================================================
# SECRETS (required for production deployment)
# =============================================================================

# NATS auth token (used in deploy/docker-compose.1m.yml and deploy/nats-1m.conf)
# NATS_TOKEN=your-nats-auth-token-here

# Hetzner server access (used by staging_videos/pipeline.sh and deploy scripts)
# HETZNER_IP=your-server-ip
# HETZNER_SSH_KEY=engram_hetzner

# Cloudflare Tunnel token (dashboard access without opening ports)
# Create at: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# =============================================================================
# INFRASTRUCTURE PORTS
# =============================================================================

# NATS Message Bus
NATS_CLIENT_PORT=4222
NATS_HTTP_PORT=8222

# Qdrant Vector Database
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Ollama LLM Server
OLLAMA_PORT=11434

# Dashboard Web UI
DASHBOARD_PORT=8080

# =============================================================================
# SAFETY CONTROL PLANE (Phase 1 hardening)
# =============================================================================
# Shared secret that signs Kernel decisions over NATS. Set the SAME value on
# the kernel AND every service that waits on a decision (coordinator, planner,
# meta-programmer). When unset, decisions are unsigned (dev mode) and a one-time
# warning is logged. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
ENGRAM_DECISION_KEY=

# Bearer token that authenticates the dashboard control plane. When set, every
# state-mutating request (POST/PUT/DELETE) and /ws connection must present it
# (Authorization: Bearer <token>, or ?token=<token> for the WebSocket). When
# unset, the control plane is open (dev mode) and a one-time warning is logged.
ENGRAM_DASHBOARD_TOKEN=

# How long a deferred (human-review) code proposal may wait before the
# meta-programmer fails it closed (rejects + DENY) instead of letting it linger.
DEFER_TTL_MS=300000

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Default code generation model (pulled on startup)
OLLAMA_CODE_MODEL=deepseek-coder:6.7b

# Embedding model for vector operations
OLLAMA_EMBED_MODEL=nomic-embed-text

# Fallback models (comma-separated)
OLLAMA_FALLBACK_MODELS=qwen2.5-coder:7b,codellama:13b

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite database path (inside container)
SQLITE_PATH=/data/sqlite/unified.db

# Qdrant collections
QDRANT_COLLECTION_TASKS=learned_tasks
QDRANT_COLLECTION_CACHE=llm_cache
QDRANT_COLLECTION_OVERRIDES=human_overrides
QDRANT_COLLECTION_MEMORY=memory_episodes

# Vector embedding dimensions (nomic-embed-text = 768)
EMBEDDING_DIMENSIONS=768

# =============================================================================
# SAFETY CONFIGURATION
# =============================================================================

# Kernel decision thresholds
KERNEL_RISK_THRESHOLD_DENY=0.8
KERNEL_RISK_THRESHOLD_DEFER=0.5

# Sandbox container limits
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=50000
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_PIDS=100

# =============================================================================
# CONFIDENCE THRESHOLDS
# =============================================================================

# Task matching confidence
TASK_HIGH_CONFIDENCE=0.85
TASK_MEDIUM_CONFIDENCE=0.6
TASK_LOW_CONFIDENCE=0.4

# LLM cache confidence
CACHE_HIT_THRESHOLD=0.95

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable NATS message tracing
NATS_TRACE_ENABLED=false

# Enable audit logging
AUDIT_ENABLED=true

# =============================================================================
# NEUROMORPHIC BRAIN CONFIGURATION
# =============================================================================

# Population sizes (neurons per region)
# NEURO_BRAINSTEM_N=15000
# NEURO_REFLEX_N=10000
# NEURO_SENSORY_N=200000
# NEURO_MOTOR_N=100000
# NEURO_CEREBELLUM_N=100000
# NEURO_ASSOCIATION_N=200000
# NEURO_PREDICTIVE_N=100000
# NEURO_WORKING_MEM_N=25000

# Hierarchical layers (0 = disabled)
# NEURO_FEATURE_N=20000
# NEURO_CONCEPT_N=5000
# NEURO_META_N=3000

# Global sparsity scale (1.0 = default, 0.5 = half synapses per pair)
# Reduce when scaling up populations to keep RAM manageable.
# NEURO_SPARSITY_SCALE=1.0

# Dendritic compartments (1 = enabled, 0 = point neurons)
# NEURO_DENDRITES=1

# Cognitive action channel (1 = enabled, 0 = disabled)
# When enabled, 15% of motor cortex becomes a "cognitive" sub-range
# that can fire to request LLM queries when prediction error is high.
# NEURO_COGNITIVE_ENABLED=1
# NEURO_EXPRESSION_END=0.85

# Simulation timestep (ms)
# NEURO_DT=1.0

# STDP update interval (steps between weight updates)
# NEURO_STDP_INTERVAL=5

# --- Preset: 1M neurons on 16GB laptop ---
# NEURO_SENSORY_N=260000
# NEURO_MOTOR_N=130000
# NEURO_CEREBELLUM_N=130000
# NEURO_ASSOCIATION_N=260000
# NEURO_PREDICTIVE_N=130000
# NEURO_WORKING_MEM_N=33000
# NEURO_FEATURE_N=26000
# NEURO_CONCEPT_N=6500
# NEURO_META_N=4000
# NEURO_SPARSITY_SCALE=0.4

# --- Preset: 3M neurons on cloud (64GB) ---
# NEURO_SENSORY_N=800000
# NEURO_MOTOR_N=400000
# NEURO_CEREBELLUM_N=400000
# NEURO_ASSOCIATION_N=800000
# NEURO_PREDICTIVE_N=400000
# NEURO_WORKING_MEM_N=100000
# NEURO_FEATURE_N=80000
# NEURO_CONCEPT_N=20000
# NEURO_META_N=12000
# NEURO_SPARSITY_SCALE=0.25

# =============================================================================
# EXTERNAL APIs (Optional)
# =============================================================================

# Claude API (for complex reasoning - optional)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional fallback)
# OPENAI_API_KEY=sk-...

# Gemini API (for video curation with Google Search grounding)
# Used by staging_videos/curate_videos.py to find training content
# Get key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key-here
