+        // balance_tao:null, 200 (unchanged error path).
+        const toRao = (v) =>
+          typeof v === "string"
+            ? BigInt(v)
+            : BigInt(Math.trunc(Number(v ?? 0)));
+        const totalRao = toRao(data.free) + toRao(data.reserved);
+        balanceTao =
+          Number(totalRao / 1_000_000_000n) +
