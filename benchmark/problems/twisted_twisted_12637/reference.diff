+            # To revert the state found at the start of the test
+            # we keep a reference and restore it later.
+            existingLoop = None
         existingPolicy = get_event_loop_policy()
         result = policy.new_event_loop()
 
         @self.addCleanup
         def cleanUp():
             result.close()
-            set_event_loop(existingLoop)
