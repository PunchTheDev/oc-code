+          await sleep(retryDelayMs(undefined, attempt, retry), signal);
+          attempt += 1;
+          continue;
+        }
+        throw error;
+      }
+      if (response.status === 304) {
+        if (cached) {
+          return cached.body as JsonResponse<Path>;
+        }
