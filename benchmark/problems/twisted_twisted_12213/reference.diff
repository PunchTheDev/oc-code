+          # Pre-release Python 3.13 with default settings.
           # For now, no dependencies as cffi doesn't work on 3.13.
           # No coverage also.
-          - python-version: '3.13.0-alpha.3'
+          - python-version: '3.13-dev'
             tox-env: 'nodeps-nocov-posix'
