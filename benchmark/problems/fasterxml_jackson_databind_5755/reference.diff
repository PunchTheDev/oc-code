diff --git a/src/main/java/tools/jackson/databind/util/BeanUtil.java b/src/main/java/tools/jackson/databind/util/BeanUtil.java
index 6ed3ceac4e..432f4534d3 100644
--- a/src/main/java/tools/jackson/databind/util/BeanUtil.java
+++ b/src/main/java/tools/jackson/databind/util/BeanUtil.java
@@ -3,6 +3,7 @@
 import java.util.Calendar;
 import java.util.Date;
 import java.util.GregorianCalendar;
+import java.util.UUID;
 
 import com.fasterxml.jackson.annotation.JsonInclude;
 
@@ -97,9 +98,12 @@ public static Object propertyDefaultValue(JavaType type, boolean wrappersAsNulls
         if (cls == String.class) {
             return "";
         }
-        if (type.isContainerType() || type.isReferenceType()) {
+        if (type.isContainerType() || type.isReferenceType()
+            // 10-Mar-2026, tatu [databind#3573]: null UUID is empty and as such default
+                || cls == UUID.class) {
             return JsonInclude.Include.NON_EMPTY;
         }
+
         // For wrapper types (Integer, Boolean, etc.), default is either null,
         // or the wrapped primitive default
         Class<?> primitiveType = ClassUtil.primitiveType(cls);
