+import assert from "node:assert/strict";
+import { describe, test } from "vitest";
+import Ajv2020 from "ajv/dist/2020.js";
+import addFormats from "ajv-formats";
+import {
+  composeCompareData,
+  growthRowsFromSamples,
+  loadCompareSubnets,
+  loadGlobalIncidents,
