+
+function pr(overrides: Partial<PullRequestRecord> & Pick<PullRequestRecord, "number">): PullRequestRecord {
+  return {
+    repoFullName: "entrius/allways-ui",
+    title: `PR #${overrides.number}`,
+    state: "open",
+    authorLogin: "miner-a",
+    labels: [],
