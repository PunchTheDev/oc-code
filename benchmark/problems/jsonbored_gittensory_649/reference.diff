+
+const FORBIDDEN = /\b(wallet|hotkey|coldkey|mnemonic|farming|payout|raw[-_\s]?trust)\b/i;
+
+const snapshot: ScoringModelSnapshotRecord = {
+  id: "score-model-fixture",
