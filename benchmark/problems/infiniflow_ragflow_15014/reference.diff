+			t.Errorf("model=%v", body["model"])
+		}
+		if body["query"] != "what is rag" {
+			t.Errorf("query=%v", body["query"])
+		}
+		docs, ok := body["documents"].([]interface{})
+		if !ok || len(docs) != 3 || docs[0] != "a" || docs[1] != "b" || docs[2] != "c" {
+			t.Errorf("documents=%v", body["documents"])
