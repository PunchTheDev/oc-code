+        assert!(ct_eq(b"act-abc", b"act-abc"));
+        assert!(!ct_eq(b"act-abc", b"act-abd"));
+        assert!(!ct_eq(b"act-abc", b"act-ab")); // differing length
+        assert!(!ct_eq(b"", b"x"));
+        assert!(ct_eq(b"", b""));
+    }
