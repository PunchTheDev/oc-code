+def _make_evaluations(uid_to_github_id: dict[int, str]) -> dict:
+    """Create mock miner evaluations mapping uid -> github_id."""
+    evaluations = {}
+    for uid, github_id in uid_to_github_id.items():
+        ev = MagicMock()
+        ev.github_id = github_id
+        evaluations[uid] = ev
+    return evaluations
+
