+++ b/spec/rubocop/cop/lint/interpolation_check_spec.rb
@@ -12,6 +12,17 @@
     RUBY
   end
 
+  it 'registers an offense and corrects when containing a closing brace without double quotes' do
+    expect_offense(<<~'RUBY')
+      'foo #{bar} }'
