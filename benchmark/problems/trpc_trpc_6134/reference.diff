+      expect(queryOptions.trpc.path).toBe('post.byId');
+      const query1 = useQuery(queryOptions);
+
+      if (!query1.data) {
+        return <>...</>;
+      }
+
+      expectTypeOf(query1.data).toMatchTypeOf<'mutated__result'>();
+
+      return <pre>{JSON.stringify(query1.data ?? 'n/a', null, 4)}</pre>;
