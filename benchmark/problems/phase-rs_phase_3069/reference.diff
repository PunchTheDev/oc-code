+    let (after_prefix, _) = alt((
+        tag::<_, _, OracleError<'_>>("whenever "),
+        tag::<_, _, OracleError<'_>>("when "),
+    ))
+    .parse(lower)
+    .ok()?;
+    let (after_venture, _) = (
+        tag::<_, _, OracleError<'_>>("you "),
+        alt((
+            tag::<_, _, OracleError<'_>>("venture into the dungeon"),
+            tag::<_, _, OracleError<'_>>("venture into the undercity"),
+        )),
+    )
+        .parse(after_prefix)
+        .ok()?;
+    Some(after_venture)
+}
