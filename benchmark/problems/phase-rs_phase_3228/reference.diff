+        // A vanilla P1 creature for the guardian to deal noncombat-style damage to.
+        let victim = scenario.add_creature(P1, "Bear", 2, 2).id();
+        let bolt1 = scenario.add_bolt_to_hand(P0);
+        let bolt2 = scenario.add_bolt_to_hand(P0);
