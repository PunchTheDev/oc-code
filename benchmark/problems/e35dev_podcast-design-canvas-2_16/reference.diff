+  border-radius: 999px;
+  padding: 4px 10px;
+}
+
+.audio-summary-preset {
+  font-weight: 700;
+  font-size: 16px;
+  margin: 0 0 4px;
+}
+
+.audio-summary-facts {
+  font-size: 13px;
+  color: var(--ink-soft);
+  margin: 10px 0 0;
