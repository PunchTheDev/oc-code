+              )}
+              href={`/channels/${channel.id}`}
+            >
+              <HashtagIcon className="h-4 w-4" />
+              {channel.name}
+            </Link>
+          ))}
+          <div className="mt-auto">
+            <div className="flex items-center justify-between">
+              <Suspense>
+                <SignedIn>
+                  <span className="text-sm font-medium">
