diff --git a/src/utils/watchlistSort.ts b/src/utils/watchlistSort.ts
new file mode 100644
index 00000000..7e943dbe
--- /dev/null
+++ b/src/utils/watchlistSort.ts
@@ -0,0 +1,10 @@
+export function compareByWatchlist<T>(
+  a: T,
+  b: T,
+  getKey: (item: T) => string | undefined,
+  isWatched: (key: string) => boolean,
+): number {
+  const aK = getKey(a);
+  const bK = getKey(b);
+  return +(aK != null && isWatched(aK)) - +(bK != null && isWatched(bK));
+}
