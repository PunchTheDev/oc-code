+func FuzzNormalizeHost(f *testing.F) {
+	f.Add("example.com")
+	f.Add("example.com.")
+	f.Add("[::1]:8080")
+	f.Add("[::1]")
+	f.Add("*.myapp.com")
+	f.Add("192.168.1.1:443")
+	f.Add("münchen.example.com")
+	f.Add("")
+	f.Fuzz(func(_ *testing.T, input string) {
+		_ = normalizeHost(input)
+	})
