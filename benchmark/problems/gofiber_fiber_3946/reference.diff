+	require.Equal(t, fiber.StatusOK, resp.StatusCode)
+
+	rid := resp.Header.Get(fiber.HeaderXRequestID)
+	require.NotEmpty(t, rid)
+	require.Len(t, rid, 43, "Should fall back to SecureToken after 3 invalid attempts")
