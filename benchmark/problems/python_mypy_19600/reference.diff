+    case (a8, b8, *rest8):
+        reveal_type(a8)  # N: Revealed type is "builtins.float | builtins.int"
+        reveal_type(b8)  # N: Revealed type is "builtins.float | builtins.str"
+        reveal_type(rest8)  # N: Revealed type is "builtins.list[builtins.float]"
