diff --git a/changelog/fix_an_error_in_style_negative_array_index.md b/changelog/fix_an_error_in_style_negative_array_index.md
new file mode 100644
index 000000000000..af15c038bc82
--- /dev/null
+++ b/changelog/fix_an_error_in_style_negative_array_index.md
@@ -0,0 +1 @@
+* [#14806](https://github.com/rubocop/rubocop/issues/14806): Fix an error in `Style/NegativeArrayIndex` when using `self` as array with implicit `self` receiver. ([@koic][])
diff --git a/lib/rubocop/cop/style/negative_array_index.rb b/lib/rubocop/cop/style/negative_array_index.rb
index 9f70a374c94f..80ed31db2a82 100644
--- a/lib/rubocop/cop/style/negative_array_index.rb
+++ b/lib/rubocop/cop/style/negative_array_index.rb
@@ -182,6 +182,8 @@ def build_range_without_parens(range_start, range_op, range_end, inner_end)
         end
 
         def receivers_match?(length_receiver, array_receiver)
+          return array_receiver.self_type? unless length_receiver
+
           unless preserving_method?(array_receiver) && preserving_method?(length_receiver)
             return false
           end
diff --git a/spec/rubocop/cop/style/negative_array_index_spec.rb b/spec/rubocop/cop/style/negative_array_index_spec.rb
index ba94fd016194..fcf46281b2d8 100644
--- a/spec/rubocop/cop/style/negative_array_index_spec.rb
+++ b/spec/rubocop/cop/style/negative_array_index_spec.rb
@@ -103,6 +103,7 @@
 
     it_behaves_like 'does not register an offense', "arr.uniq[arr.uniq.compact.#{method_name} - 2]"
     it_behaves_like 'does not register an offense', "arr.flatten[arr.flatten.map(&:to_s).#{method_name} - 2]"
+    it_behaves_like 'does not register an offense', "arr[#{method_name} - 2]"
     it_behaves_like 'does not register an offense', "arr[other.#{method_name} - 2]"
     it_behaves_like 'does not register an offense', "@arr[@other.#{method_name} - 2]"
     it_behaves_like 'does not register an offense', "CONST[OTHER.#{method_name} - 2]"
@@ -241,5 +242,23 @@
     it_behaves_like 'registers an offense for range with parentheses but without expression parentheses', 'arr', method_name, 2, '..', 2
     it_behaves_like 'registers an offense for range with parentheses but without expression parentheses', 'arr.sort', method_name, 0, '..', 2
     it_behaves_like 'registers an offense for range with parentheses but without expression parentheses', 'arr.reverse', method_name, 0, '..', 2
+
+    it "does not register an offense when using `self` as array with local variable receiver for #{method_name}" do
+      expect_no_offenses(<<~RUBY)
+        #{method_name} = do_something
+        self[#{method_name} - 1]
+      RUBY
+    end
+
+    it "registers an offense when using `self` as array with implicit receiver for #{method_name}" do
+      expect_offense(<<~RUBY, method_name: method_name)
+        self[%{method_name} - 1]
+             ^{method_name}^^^^ Use `self[-1]` instead of `self[#{method_name} - 1]`.
+      RUBY
+
+      expect_correction(<<~RUBY)
+        self[-1]
+      RUBY
+    end
   end
 end
