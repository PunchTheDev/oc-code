+  function assertNotNamedExport(
+    node: Positioned<VariableDeclaration>,
+    error: string,
+  ) {
+    const nodeExported = findNodeAround(
+      ast,
+      node.start,
+      'ExportNamedDeclaration',
+    )?.node as Positioned<ExportNamedDeclaration> | undefined
