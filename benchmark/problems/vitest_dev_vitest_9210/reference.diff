+    dynamicImportMockMethodNames = ['mock', 'unmock', 'doMock', 'doUnmock'],
+    hoistedMethodNames = ['hoisted'],
+    utilsObjectNames = ['vi', 'vitest'],
+    hoistedModule = 'vitest',
+  } = options
