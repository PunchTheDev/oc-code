+  }
+
+  function assertNotDefaultExport(
+    node: Positioned<CallExpression>,
+    error: string,
+  ) {
+    const defaultExport = findNodeAround(
+      ast,
+      node.start,
+      'ExportDefaultDeclaration',
+    )?.node as Positioned<ExportDefaultDeclaration> | undefined
