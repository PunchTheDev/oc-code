+        /^\[/ && !/^\[core\]/ { in_core = 0 }
+        in_core && /^wakeword_script = / { found = 1; print $2; exit }
+        END { if (!found) print "__missing__" }
+    ' "$CONFIG_FILE" 2>/dev/null || true
+}
+
