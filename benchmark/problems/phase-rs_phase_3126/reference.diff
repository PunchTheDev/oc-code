+    assert!(
+        events
+            .iter()
+            .any(|e| matches!(e, GameEvent::ChaosEnsued { plane_id: id } if *id == plane_id)),
+        "ChaosEnsued event keyed to the active plane emitted"
+    );
+    assert_eq!(
