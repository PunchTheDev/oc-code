@@ -41,7 +41,7 @@ def foo
         def foo
           @current_user ||= User.find_by(id: session[:user_id])
           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Avoid memoizing `find_by` results with `||=`.
