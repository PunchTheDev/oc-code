diff --git a/changelog/fix_incorrect_autocorrect_for_style_redundant_regexp_argument_cop.md b/changelog/fix_incorrect_autocorrect_for_style_redundant_regexp_argument_cop.md
new file mode 100644
index 000000000000..450aac0dc965
--- /dev/null
+++ b/changelog/fix_incorrect_autocorrect_for_style_redundant_regexp_argument_cop.md
@@ -0,0 +1 @@
+* [#14543](https://github.com/rubocop/rubocop/issues/14543): Fix an incorrect autocorrect for `Style/RedundantRegexpArgument` when using escaped single quote character. ([@koic][])
diff --git a/lib/rubocop/cop/style/redundant_regexp_argument.rb b/lib/rubocop/cop/style/redundant_regexp_argument.rb
index cf7757466d96..0271516df15f 100644
--- a/lib/rubocop/cop/style/redundant_regexp_argument.rb
+++ b/lib/rubocop/cop/style/redundant_regexp_argument.rb
@@ -66,6 +66,7 @@ def determinist_regexp?(regexp_node)
           DETERMINISTIC_REGEX.match?(regexp_node.source)
         end
 
+        # rubocop:disable Metrics/MethodLength
         def preferred_argument(regexp_node)
           new_argument = replacement(regexp_node)
 
@@ -73,6 +74,8 @@ def preferred_argument(regexp_node)
             new_argument.gsub!("'", "\\\\'")
             new_argument.gsub!('\"', '"')
             quote = "'"
+          elsif new_argument.include?("\\'")
+            quote = "'"
           elsif new_argument.include?('\'')
             new_argument.gsub!("'", "\\\\'")
             quote = "'"
@@ -84,6 +87,7 @@ def preferred_argument(regexp_node)
 
           "#{quote}#{new_argument}#{quote}"
         end
+        # rubocop:enable Metrics/MethodLength
 
         def replacement(regexp_node)
           regexp_content = regexp_node.content
diff --git a/spec/rubocop/cop/style/redundant_regexp_argument_spec.rb b/spec/rubocop/cop/style/redundant_regexp_argument_spec.rb
index a2b919cf16c5..b0c64a48e605 100644
