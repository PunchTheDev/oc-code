+/* ---- Home screen focus (#112) --------------------------------------------- */
+
+.home-screen {
+  display: grid;
+  gap: 18px;
+}
+
+.home-screen-header {
+  margin-bottom: 0;
+}
+
+.home-start-hero {
+  display: grid;
+  gap: 14px;
+  padding: 24px 26px;
+  border: 1px solid rgba(108, 76, 255, 0.18);
+  background:
+    linear-gradient(135deg, rgba(108, 76, 255, 0.08), rgba(255, 122, 89, 0.06)),
+    var(--surface);
+  box-shadow: var(--shadow);
+}
+
+.home-start-title {
+  margin: 0;
+  font-size: clamp(22px, 3vw, 28px);
+  letter-spacing: -0.02em;
+}
+
+.home-start-lead {
+  margin: 0;
+  max-width: 52ch;
+}
+
+.home-primary-cta {
+  justify-self: start;
+  min-width: min(100%, 320px);
+  padding: 14px 22px;
+  font-size: 16px;
+  box-shadow: 0 10px 28px rgba(108, 76, 255, 0.22);
+}
+
+.home-secondary-links {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px 16px;
+}
+
+.home-explore-panel {
+  display: grid;
+  gap: 10px;
+  padding: 18px 20px;
+  background: rgba(255, 255, 255, 0.72);
+}
+
+.home-explore-title {
+  margin: 0;
+  font-size: 15px;
+  color: var(--ink-soft);
+  font-weight: 700;
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+}
+
+.home-explore-links {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px 18px;
+}
+
+.home-gallery-spotlight {
+  display: grid;
+  gap: 16px;
+}
+
+.home-gallery-spotlight-head {
+  display: grid;
+  gap: 8px;
+}
+
+.home-gallery-thumb-grid {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
+  gap: 12px;
+}
+
+.home-gallery-thumb-card {
+  display: grid;
+  gap: 8px;
+  padding: 10px;
+  border: 1px solid var(--line);
+  border-radius: 14px;
+  background: #fcfcff;
+  text-align: left;
+  cursor: pointer;
+  transition: border-color 0.15s ease, box-shadow 0.15s ease;
+}
+
+.home-gallery-thumb-card:hover {
+  border-color: rgba(108, 76, 255, 0.45);
+  box-shadow: 0 8px 24px rgba(20, 16, 60, 0.08);
+}
+
+.home-gallery-thumb-card .creator-gallery-preview-thumb {
+  min-height: 112px;
+}
+
+.home-gallery-thumb-name {
+  font-weight: 700;
+  font-size: 14px;
+}
+
+.home-gallery-thumb-meta {
+  font-size: 12px;
+  color: var(--ink-soft);
+}
+
+.home-gallery-spotlight-actions {
+  display: flex;
+  flex-wrap: wrap;
+  align-items: center;
+  gap: 12px 18px;
+}
+
+.home-gallery-secondary-link {
+  font-size: 14px;
+}
+
+@media (max-width: 640px) {
+  .home-primary-cta {
+    width: 100%;
+  }
+}
+
