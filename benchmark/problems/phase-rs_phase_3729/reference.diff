+#[test]
+fn identity_is_energy_payoff() {
+    assert_eq!(policy().id(), PolicyId::EnergyPayoff);
+    assert!(policy().decision_kinds().contains(&DecisionKind::CastSpell));
+    assert!(!policy().decision_kinds().contains(&DecisionKind::PlayLand));
+}
