+        ],
+      },
+      analysis: {
+        baseFreshness: {
+          status: "fresh",
+          changedFileCount: 3,
+          testFileCount: 0,
+          passedValidationCount: 0,
+          warnings: [],
+        },
+        branchQualityBlockers: [],
+        accountStateBlockers: ["Open PR count is high."],
