+      end
+
+      it 'registers an offense for itblock on separate lines', :ruby34 do
+        expect_offense(<<~RUBY)
+          bars =
+          ^^^^^^ Right hand side of multi-line assignment is not on the same line as the assignment operator `=`.
+            foo.map {
+              it.bar
+            }
+        RUBY
+      end
     end
