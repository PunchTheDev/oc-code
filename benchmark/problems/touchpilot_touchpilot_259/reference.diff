+            activeSkillRisk = activeSkillRisk
+        )
+    }
+
+    private fun mediumTool(name: String): ToolSpec {
+        return ToolSpec(
+            name = name,
+            description = "Test tool",
+            risk = ToolRisk.MEDIUM,
+            arguments = emptyMap(),
+            requiredArguments = emptySet()
+        )
