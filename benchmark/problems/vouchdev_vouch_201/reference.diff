+def _write_poisoned_claim(store: KBStore, claim: Claim) -> None:
+    """Plant a claim YAML directly, bypassing put_claim's ref guard."""
+    (store.kb_dir / "claims" / f"{claim.id}.yaml").write_text(
+        _yaml_dump(claim.model_dump(mode="json"))
+    )
+
