+      expect_no_offenses(<<~RUBY)
+        <<~HTML.html_safe
+          foo
+        HTML
+      RUBY
+    end
+
+    it 'registers an offense for dynamic single line heredoc receiver' do
+      expect_offense(<<~'RUBY')
+        <<~HTML.html_safe
