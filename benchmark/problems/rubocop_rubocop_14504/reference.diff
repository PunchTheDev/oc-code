diff --git a/changelog/fix_string_concat_interpolation.md b/changelog/fix_string_concat_interpolation.md
new file mode 100644
index 000000000000..1efa3096f2a9
--- /dev/null
+++ b/changelog/fix_string_concat_interpolation.md
@@ -0,0 +1 @@
+* [#14502](https://github.com/rubocop/rubocop/issues/14502): Fix wrong autocorrect for `Style/StringConcatenation` when a single-quoted string contains interpolation like `'#{foo}'`. ([@earlopain][])
diff --git a/lib/rubocop/cop/style/string_concatenation.rb b/lib/rubocop/cop/style/string_concatenation.rb
index c6cd17148490..b275f12d1355 100644
--- a/lib/rubocop/cop/style/string_concatenation.rb
+++ b/lib/rubocop/cop/style/string_concatenation.rb
@@ -149,7 +149,11 @@ def replacement(parts)
         def adjust_str(part)
           case part.type
           when :str
-            single_quoted?(part) ? part.value.gsub(/(\\|")/, '\\\\\&') : part.value.inspect[1..-2]
+            if single_quoted?(part)
+              part.value.gsub(/(\\|"|#\{|#@|#\$)/, '\\\\\&')
+            else
+              part.value.inspect[1..-2]
+            end
           when :dstr, :begin
             part.children.map do |child|
               adjust_str(child)
