+# these, is a classic way to reach a dangerous attribute while evading the
+# regex (e.g. getattr(os, "sys" + "tem"), getattr(__builtins__, "eval")).
+DYNAMIC_ATTR_BUILTINS = {"getattr", "setattr", "delattr"}
